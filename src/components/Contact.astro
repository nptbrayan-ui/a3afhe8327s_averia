---

---

<section id="contact" class="scroll-mt-20 border-t border-ink/10 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-xs font-medium uppercase tracking-[0.15em] text-accent">Contact</p>
    <h2 class="font-display mt-4 text-4xl font-bold leading-tight tracking-tight md:text-5xl">
      Get in touch
    </h2>
    <div class="mt-16 grid gap-16 md:grid-cols-2">
      <form name="contact" netlify class="flex flex-col gap-5" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>
            Don't fill this out: <input name="bot-field" />
          </label>
        </p>
        <div>
          <label for="name" class="mb-2 block text-xs font-medium uppercase tracking-wider text-ink">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            class="w-full border border-ink/10 bg-white px-4 py-3 text-sm placeholder:text-ink/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="mb-2 block text-xs font-medium uppercase tracking-wider text-ink">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="w-full border border-ink/10 bg-white px-4 py-3 text-sm placeholder:text-ink/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="message" class="mb-2 block text-xs font-medium uppercase tracking-wider text-ink">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full border border-ink/10 bg-white px-4 py-3 text-sm placeholder:text-ink/30 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
            placeholder="Tell us what's on your mind..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="self-start bg-accent px-8 py-3 text-xs font-medium uppercase tracking-wider text-white transition-all hover:bg-accent-dark"
        >
          Send Message
        </button>
      </form>

      <div class="flex flex-col justify-center gap-8 border-l border-accent/20 pl-8">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-ink/40">Email</p>
          <a href="mailto:aveirasmartclock@gmail.com" class="mt-2 block text-sm text-ink transition-colors hover:text-accent">
            aveirasmartclock@gmail.com
          </a>
        </div>
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-ink/40">Follow</p>
          <div class="mt-3 flex gap-4">
            <a href="https://www.instagram.com/aveirasmartclocks/" target="_blank" rel="noopener noreferrer" class="text-ink/40 transition-colors hover:text-accent" aria-label="Instagram">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <circle cx="12" cy="12" r="5" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
              </svg>
            </a>
            <a href="https://www.tiktok.com/@aveiraclocks" target="_blank" rel="noopener noreferrer" class="text-ink/40 transition-colors hover:text-accent" aria-label="TikTok">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
