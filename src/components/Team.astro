---
const team = [
  {
    name: 'Brayan Nguyen',
    role: 'Designer',
    bio: 'Shapes the look and feel of Aveira.',
    photo: '/headshot-brayan.jpeg',
  },
  {
    name: 'Nikhil Tadepalli',
    role: 'Business & Lead',
    bio: 'Drives the vision and strategy.',
    photo: '/headshot-nikhil.jpeg',
  },
  {
    name: 'Vivaan Agarwaal',
    role: 'Software',
    bio: 'Builds the firmware and software.',
    photo: '',
  },
  {
    name: 'Arnav Sharma',
    role: 'Finance & Planning',
    bio: 'Manages funding, budget, and timelines.',
    photo: '/headshot-arnav.jpeg',
  },
];
---

<section id="team" class="scroll-mt-20 border-t border-ink/10 bg-beige/20 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-xs font-medium uppercase tracking-[0.15em] text-accent">Team</p>
    <h2 class="mt-4 text-3xl font-bold leading-tight tracking-tight md:text-4xl">
      The people behind Aveira
    </h2>
    <div class="mt-16 grid gap-px bg-ink/10 md:grid-cols-4">
      {team.map((m) => (
        <div class="flex flex-col gap-4 bg-warm-white p-8">
          {m.photo ? (
            <img
              src={m.photo}
              alt={m.name}
              class="h-24 w-24 object-cover border border-ink/20"
              loading="lazy"
            />
          ) : (
            <div class="flex h-24 w-24 items-center justify-center border border-ink/20 text-xs font-bold uppercase tracking-widest text-ink/40">
              VA
            </div>
          )}
          <div>
            <h3 class="font-display text-lg font-bold tracking-tight">{m.name}</h3>
            <p class="mt-0.5 text-xs font-medium uppercase tracking-wider text-accent">{m.role}</p>
          </div>
          <p class="text-sm leading-relaxed text-ink/50">{m.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>
