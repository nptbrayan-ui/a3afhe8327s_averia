<section id="gallery" class="scroll-mt-20 border-t border-ink/10 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-xs font-medium uppercase tracking-[0.15em] text-accent">Gallery</p>
    <h2 class="font-display mt-4 text-3xl font-bold leading-tight tracking-tight md:text-4xl">
      Product in context
    </h2>
    <div class="mt-16 grid gap-px bg-ink/10 md:grid-cols-2">
      <div class="aspect-[4/3] bg-beige">
        <img
          src="/package1.png"
          alt="Aveira Clock — Design render"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="aspect-[4/3] bg-beige">
        <img
          src="/package2.png"
          alt="Aveira Clock — Prototype photo"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="aspect-[4/3] bg-beige">
        <div class="flex h-full flex-col items-center justify-center gap-4 bg-ink p-8 text-center">
          <p class="text-xs font-medium uppercase tracking-widest text-white/40">Coming Soon</p>
          <p class="text-sm leading-relaxed text-white/60">
            Product photography arriving<br />with our first prototype batch.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
