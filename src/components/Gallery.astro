<section id="gallery" class="scroll-mt-20 border-t border-ink/10 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="font-display text-4xl font-bold leading-tight tracking-tight text-accent md:text-5xl">Gallery</h2>
    <div class="mt-12 grid gap-px bg-ink/10 md:grid-cols-2">
      <div class="aspect-[3/2] bg-beige overflow-hidden">
        <img
          src="/package1.png"
          alt="Aveira Clock - Design render"
          class="h-full w-full object-cover transition-transform duration-700 hover:scale-105"
          loading="lazy"
        />
      </div>
      <div class="aspect-[3/2] bg-beige overflow-hidden">
        <img
          src="/package2.png"
          alt="Aveira Clock - Prototype photo"
          class="h-full w-full object-cover transition-transform duration-700 hover:scale-105"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
